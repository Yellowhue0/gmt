generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  TRAINER
  FIGHTER
  FINANCE
  ADMIN
  PARENT
  JUNIOR
}

enum ClassType {
  REGULAR
  SPECIAL
  FIGHTERS_ONLY
  KIDS_ONLY
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(MEMBER)
  swishNumber          String?
  phone                String?
  bio                  String?
  avatarUrl            String?
  usernameChangesCount Int       @default(0)
  membershipPaid       Boolean   @default(false)
  membershipStart      DateTime?
  membershipEnd        DateTime? @map("membershipExpiry")
  resetToken           String?
  resetTokenExpiry     DateTime?
  isConfirmed          Boolean   @default(false)
  confirmedAt          DateTime?
  confirmedBy          String?
  isLocked             Boolean   @default(false)
  lockedReason         String?
  lockedAt             DateTime?
  lockedBy             String?
  fullName           String?
  fighterCardNumber  String?
  fighterCardExpiry  DateTime?
  weightClass        String?
  currentWeight      Float?
  wins               Int       @default(0)
  losses             Int       @default(0)
  draws              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  checkIns           CheckIn[]
  posts              Post[]
  comments           Comment[]
  sessions           GymSession[]              @relation("TrainerSessions")
  notifications      Notification[]
  eventAttendees     EventAttendee[]
  createdEvents      Event[]                   @relation("EventCreator")
  confirmedSessions  SessionConfirmedTrainer[]
  assignedSessions   SessionAssignedTrainer[]
  children           ChildMember[]             @relation("ParentChildren")
  competitionEntries FighterCompetitionEntry[] @relation("FighterEntries")
  eventComments      EventComment[]            @relation("EventCommentAuthor")
}

model ChildMember {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  parentId        String
  parent          User      @relation("ParentChildren", fields: [parentId], references: [id])
  isConfirmed     Boolean   @default(false)
  membershipPaid  Boolean   @default(false)
  membershipStart DateTime?
  membershipEnd   DateTime?
  createdAt       DateTime  @default(now())

  checkIns ChildCheckIn[]
}

model ChildCheckIn {
  id        String      @id @default(cuid())
  childId   String
  child     ChildMember @relation(fields: [childId], references: [id], onDelete: Cascade)
  sessionId String
  session   GymSession  @relation(fields: [sessionId], references: [id])
  date      String
  createdAt DateTime    @default(now())

  @@unique([childId, sessionId, date])
}

model GymSession {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  dayOfWeek          Int
  startTime          String
  endTime            String
  type               String    @default("regular")
  classType          ClassType @default(REGULAR)
  visibility         String    @default("PUBLIC")
  trainerId          String?
  trainer            User?     @relation("TrainerSessions", fields: [trainerId], references: [id])
  maxCapacity        Int       @default(20)
  isActive           Boolean   @default(true)
  isRecurring        Boolean   @default(true)
  specificDate       DateTime?
  seriesId           String?
  isCancelled        Boolean   @default(false)
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledBy        String?
  createdAt          DateTime  @default(now())

  checkIns          CheckIn[]
  childCheckIns     ChildCheckIn[]
  confirmedTrainers SessionConfirmedTrainer[]
  assignedTrainers  SessionAssignedTrainer[]
}

model SessionAssignedTrainer {
  sessionId  String
  userId     String
  assignedBy String?
  assignedAt DateTime   @default(now())
  session    GymSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model SessionConfirmedTrainer {
  sessionId String
  userId    String
  session   GymSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model CheckIn {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  sessionId String
  session   GymSession @relation(fields: [sessionId], references: [id])
  date      String
  notes     String?
  createdAt DateTime   @default(now())

  @@unique([userId, sessionId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  hostName    String?
  type        String   @default("COMPETITION")
  createdById String?
  createdBy   User?    @relation("EventCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  attendees          EventAttendee[]
  competitionEntries FighterCompetitionEntry[]
  comments           EventComment[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model FighterCompetitionEntry {
  id            String   @id @default(cuid())
  fighterId     String
  fighter       User     @relation("FighterEntries", fields: [fighterId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  weightAtEntry Float?
  opponent      String?
  result        String?
  notes         String?
  enteredBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  targetUser  String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  pinned    Boolean  @default(false)
  category  String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("EventCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  parentId  String?
  parent    EventComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   EventComment[] @relation("CommentReplies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
