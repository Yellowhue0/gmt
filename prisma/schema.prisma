generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  TRAINER
  FIGHTER
  FINANCE
  ADMIN
}

enum ClassType {
  REGULAR
  SPECIAL
  FIGHTERS_ONLY
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(MEMBER)
  swishNumber          String?
  phone                String?
  bio                  String?
  avatarUrl            String?
  usernameChangesCount Int       @default(0)
  membershipPaid       Boolean   @default(false)
  membershipStart      DateTime?
  membershipEnd        DateTime? @map("membershipExpiry")
  resetToken           String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  checkIns          CheckIn[]
  posts             Post[]
  comments          Comment[]
  sessions          GymSession[]             @relation("TrainerSessions")
  notifications     Notification[]
  eventAttendees    EventAttendee[]
  createdEvents     Event[]                  @relation("EventCreator")
  confirmedSessions SessionConfirmedTrainer[]
  assignedSessions  SessionAssignedTrainer[]
}

model GymSession {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  dayOfWeek          Int
  startTime          String
  endTime            String
  type               String    @default("regular")
  classType          ClassType @default(REGULAR)
  visibility         String    @default("PUBLIC")
  trainerId          String?
  trainer            User?     @relation("TrainerSessions", fields: [trainerId], references: [id])
  maxCapacity        Int       @default(20)
  isActive           Boolean   @default(true)
  isRecurring        Boolean   @default(true)
  specificDate       DateTime?
  seriesId           String?
  isCancelled        Boolean   @default(false)
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledBy        String?
  createdAt          DateTime  @default(now())

  checkIns          CheckIn[]
  confirmedTrainers SessionConfirmedTrainer[]
  assignedTrainers  SessionAssignedTrainer[]
}

model SessionAssignedTrainer {
  sessionId  String
  userId     String
  assignedBy String?
  assignedAt DateTime   @default(now())
  session    GymSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model SessionConfirmedTrainer {
  sessionId String
  userId    String
  session   GymSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model CheckIn {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  sessionId String
  session   GymSession @relation(fields: [sessionId], references: [id])
  date      String
  notes     String?
  createdAt DateTime   @default(now())

  @@unique([userId, sessionId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  hostName    String?
  type        String   @default("COMPETITION")
  createdById String?
  createdBy   User?    @relation("EventCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  attendees EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  targetUser  String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  pinned    Boolean  @default(false)
  category  String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}
